# NextAuth
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me

# Optional OAuth providers (enable by setting both ID and SECRET)
# GOOGLE_ID=
# GOOGLE_SECRET=
# GITHUB_ID=
# GITHUB_SECRET=
# FACEBOOK_ID=
# FACEBOOK_SECRET=

# Backend (Flask)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:5001
